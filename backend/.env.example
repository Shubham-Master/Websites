NODE_ENV=development
PORT=4000
HOST=0.0.0.0
APP_URL=http://localhost:4000
# Use * only for local development. In production set your frontend domain(s), comma-separated.
CORS_ORIGIN=*
BOOKING_HOLD_MINUTES=10
TRUST_PROXY=false
# Set this to your Supabase Postgres connection string to enable persistent storage.
DATABASE_URL=
# Supabase direct Postgres connections usually require SSL.
DATABASE_SSL=true
# Optional: Resend API key for free-session confirmation emails.
RESEND_API_KEY=
# Optional: verified sender, for example Unmute <hello@yourdomain.com>
EMAIL_FROM=
# Optional: reply-to address for confirmations.
EMAIL_REPLY_TO=
